{
  "name": "balloon-planner",
  "version": "1.5.2",
  "description": "An application to plan hot air balloon crews for youth camps",
  "productName": "Balloon Planner",
  "author": "marvin-wtt <31454580+marvin-wtt@users.noreply.github.com>",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "quasar prepare",
    "lint": "vue-tsc --noEmit && eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "dev": "quasar dev -m electron",
    "build": "quasar build -m electron"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.2",
    "electron-log": "^5.4.4",
    "html-to-image": "^1.11.13",
    "papaparse": "^5.5.4",
    "pinia": "^3.0.4",
    "quasar": "^2.21.4",
    "vue": "3.5.40",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@quasar/app-vite": "^3.0.1",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "autoprefixer": "^10.5.4",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-updater": "^6.8.9",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "6.0.3",
    "vite-plugin-checker": "^0.14.4",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": "^24",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "electron-winstaller@5.4.0": true
  }
}
